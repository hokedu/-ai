{
  "name": "ai-simultaneous-translation-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:start": "electron ."
  },
  "build": {
    "appId": "com.ai-simultaneous-translation.assistant",
    "productName": "AI 同声传译助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "node_modules/**/*",
      ".env.example"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@vitalets/google-translate-api": "^9.2.1",
    "@vitejs/plugin-react": "^4.3.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.4",
    "https-proxy-agent": "^8.0.0",
    "openai": "^6.42.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.1"
  }
}
